{
  "name": "slots888",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web,admin -c blue,green,magenta \"npm run dev -w apps/server\" \"npm run dev -w apps/web\" \"npm run dev -w apps/admin\"",
    "test": "npm run test -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "simulate": "npm run simulate -w packages/engine",
    "e2e": "node scripts/e2e-smoke.mjs",
    "e2e:admin": "node scripts/e2e-admin-configs.mjs",
    "e2e:features": "node scripts/e2e-features.mjs",
    "e2e:stats": "node scripts/e2e-stats.mjs",
    "e2e:ante": "node scripts/e2e-ante.mjs",
    "e2e:topup": "node scripts/e2e-admin-topup.mjs",
    "e2e:restore": "node scripts/e2e-restore.mjs",
    "e2e:history": "node scripts/e2e-history.mjs",
    "e2e:rtp": "node scripts/e2e-rtp.mjs",
    "e2e:bonusbuy": "node scripts/e2e-bonusbuy.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.61.1",
    "typescript": "^5.8.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "better-sqlite3@12.11.1": true
  }
}
